# Copy this file to .env and fill in your own values

# ====== APP CONFIGURATION ======
# Public app URL for redirects, webhooks, and external links
APP_URL=https://membersonly.applejucy.com
APP_NAME=Members Only

# ====== SERVER PORTS & CORS ======
PORT=3001
CORS_ORIGIN=https://membersonly.applejucy.com

# ====== POCKETBASE CONFIGURATION ======
# PocketBase runs on separate server
# Get these values from PocketBase admin panel (/admin)
POCKETBASE_URL=http://localhost:8090
POCKETBASE_FRONTEND_URL=http://localhost:3000
PB_EMAIL=admin@example.com
PB_PASSWORD=1234567890

# Encryption key for PocketBase (MUST be 32 bytes, use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PB_ENCRYPTION_KEY=12345678901234567890123456789012
PB_SUPERUSER_EMAIL=admin@applejucy.com
PB_SUPERUSER_PASSWORD=1234567890

# ====== PAYPAL INTEGRATION - SANDBOX (Testing) ======
# Get these from https://developer.paypal.com/dashboard
# 1. Select Sandbox mode
# 2. Go to Apps & Credentials
# 3. Copy Client ID and Secret from Sandbox Business account

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_sandbox_client_id_here
PAYPAL_CLIENT_SECRET=your_sandbox_client_secret_here

# Webhook Configuration - IMPORTANT
# Steps to get PAYPAL_WEBHOOK_ID:
# 1. Go to https://developer.paypal.com/dashboard/webhooks
# 2. Click "Create webhook endpoint"
# 3. Enter URL: https://membersonly.applejucy.com/api/billing/paypal/webhook
# 4. Select these events:
#    - BILLING.SUBSCRIPTION.CREATED
#    - BILLING.SUBSCRIPTION.ACTIVATED
#    - BILLING.SUBSCRIPTION.TRIALING
#    - BILLING.SUBSCRIPTION.PAYMENT.SUCCESS
#    - BILLING.SUBSCRIPTION.CANCELLED
#    - BILLING.SUBSCRIPTION.EXPIRED
#    - BILLING.SUBSCRIPTION.SUSPENDED
#    - BILLING.SUBSCRIPTION.PAST_DUE
# 5. Copy the Webhook ID from the endpoint details
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# PayPal Plans (Subscription IDs for each tier)
# Create these in PayPal dashboard:
# 1. Go to Recurring Billing → Billing Plans
# 2. Create a Product first (name: "Fan Club", "VIP Lounge", "Elite Lounge")
# 3. Create Subscription Plan for that product:
#    - Billing Frequency: Monthly
#    - Pricing: Set monthly amount
#    - Trial Period: 14 days
# 4. Copy the Plan ID here
PAYPAL_PLAN_ID_FAN_MONTHLY=L3MKECMJ7PA52
PAYPAL_PLAN_ID_VIP_MONTHLY=E23D4H78JSZCY
PAYPAL_PLAN_ID_ELITE_MONTHLY=CPNYX2PLPG6CU

# ====== PAYPAL INTEGRATION - LIVE (Production) ======
# ONLY switch to live when ready for real payments
# Repeat steps above using Live mode instead of Sandbox
# PAYPAL_MODE=live
# PAYPAL_CLIENT_ID=your_live_client_id_here
# PAYPAL_CLIENT_SECRET=your_live_client_secret_here
# PAYPAL_WEBHOOK_ID=your_live_webhook_id_here
# PAYPAL_PLAN_ID_FAN_MONTHLY=your_live_fan_plan_id
# PAYPAL_PLAN_ID_VIP_MONTHLY=your_live_vip_plan_id
# PAYPAL_PLAN_ID_ELITE_MONTHLY=your_live_elite_plan_id

# ====== ALTERNATIVE PAYMENT PROVIDERS ======
# Gumroad (optional, for alternative checkout)
GUMROAD_WEBHOOK_SECRET=your_gumroad_webhook_secret_here

# ====== LOGGING & DEBUGGING ======
LOG_LEVEL=info
NODE_ENV=development

# ====== GOOGLE OAUTH 2.0 CONFIGURATION ======
# Setup steps:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or select existing)
# 3. Enable "Google+ API" in APIs & Services
# 4. Go to "Credentials" and create OAuth 2.0 Client ID
# 5. Choose "Web application"
# 6. Add authorized redirect URIs:
#    - http://localhost:3000/oauth2-callback (development)
#    - https://membersonly.applejucy.com/oauth2-callback (production)
# 7. Copy the Client ID and Secret here

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ====== JWT CONFIGURATION (Optional) ======
# If implementing JWT for API authentication beyond PocketBase
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d
